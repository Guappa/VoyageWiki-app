---
import VoyageWordmark from "~/components/static/VoyageWordmark.astro";
const buildDate = new Date().toISOString().slice(0, 10);
---
<footer class="site-footer">
  <span class="site-footer__build">Build: {buildDate}</span>
  <span class="site-footer__center">VoyageWiki V33 schema reference &middot; <a href="/tools/api">API</a></span>
  <a class="play-voyage" href="https://voyage.io/" target="_blank" rel="noopener">
    <span class="play-voyage__body">
      <span class="play-voyage__label">Play Voyage</span>
      <span aria-hidden="true">
        <VoyageWordmark class="play-voyage__wordmark" />
      </span>
    </span>
    <span class="play-voyage__arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M8 7h9v9"/></svg>
    </span>
  </a>
</footer>
